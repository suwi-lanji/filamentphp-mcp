{
  "name": "filamentphp-mcp",
  "version": "1.0.0",
  "description": "MCP server for accessing FilamentPHP documentation - enables AI agents to query and retrieve FilamentPHP docs, components, and API references",
  "main": "dist/index.js",
  "bin": {
    "filamentphp-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "filamentphp",
    "laravel",
    "docs",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
